{
  "name": "sportcation-web-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "next build",
    "auth:bootstrap": "tsx lib/auth/bootstrap.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx lib/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate:postgres": "drizzle-kit generate --config drizzle.postgres.config.ts",
    "dev": "next dev",
    "deploy:check": "tsx scripts/production-preflight.ts",
    "lint": "eslint .",
    "start": "next start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "tsx tests/e2e/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.16",
    "@libsql/client": "^0.17.3",
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/analytics": "1.3.1",
    "better-auth": "^1.6.16",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.42.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.454.0",
    "next": "^16.2.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/env": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "postcss": "8.5.10",
    "tailwindcss": "^4.1.9",
    "tsx": "^4.22.4",
    "tw-animate-css": "1.3.3",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.10",
    "esbuild": "$esbuild"
  }
}
