{
  "name": "sportcation-monorepo",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace=apps/admin",
    "dev:merchant": "npm run dev --workspace=apps/merchant",
    "dev:client": "npm run dev --workspace=apps/client",
    "dev:api": "npm run dev --workspace=apps/api",
    "build:admin": "npm run build --workspace=apps/admin",
    "build:merchant": "npm run build --workspace=apps/merchant",
    "build:client": "npm run build --workspace=apps/client",
    "build:api": "npm run build --workspace=apps/api",
    "build:all": "npm run build:api && npm run build:admin && npm run build:merchant && npm run build:client",
    "typecheck:admin": "npm run typecheck --workspace=apps/admin",
    "typecheck:merchant": "npm run typecheck --workspace=apps/merchant",
    "typecheck:client": "npm run typecheck --workspace=apps/client",
    "typecheck:api": "npm run typecheck --workspace=apps/api",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx packages/shared-lib/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
