# Active SQLite-compatible persistence.
# Local development:
TURSO_DATABASE_URL="file:./data/sportcation.db"
TURSO_AUTH_TOKEN=""

# Production (Vercel or another stateless host):
# TURSO_DATABASE_URL="libsql://YOUR_DATABASE.turso.io"
# TURSO_AUTH_TOKEN="YOUR_TURSO_TOKEN"

# Reserved for the planned Neon PostgreSQL migration.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Required for authentication. Use at least 32 random characters.
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
AUTH_TRUSTED_ORIGINS="http://localhost:3000"
# Optional auth rate-limit overrides. Leave empty for secure defaults.
AUTH_SIGN_IN_RATE_LIMIT_MAX=""
AUTH_SIGN_UP_RATE_LIMIT_MAX=""

# Optional one-time bootstrap credentials. Never commit real values.
AUTH_BOOTSTRAP_ADMIN_EMAIL=""
AUTH_BOOTSTRAP_ADMIN_PASSWORD=""
AUTH_BOOTSTRAP_ADMIN_NAME="Sportcation Admin"
AUTH_BOOTSTRAP_MERCHANT_EMAIL=""
AUTH_BOOTSTRAP_MERCHANT_PASSWORD=""
AUTH_BOOTSTRAP_MERCHANT_NAME="Sportcation Merchant"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Bayar.gg Payment Gateway
BAYAR_GG_API_KEY=""

# Vercel Cron Secret (auto-set by Vercel, or set manually for local testing)
CRON_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Deployment Role Isolation (for multi-deployment setup)
# Values: "customer" | "merchant" | "admin" | leave empty for all routes
# Each Vercel project sets this to expose only relevant routes
DEPLOYMENT_ROLE=""
