generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  GUEST
  USER
  PARTNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum VenueStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CourtStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum SlotStatus {
  AVAILABLE
  HELD
  BOOKED
  BLOCKED
  EXPIRED
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  EXPIRED
  FAILED
}

enum BookingItemStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentProvider {
  SIMULATION
  XENDIT
  MIDTRANS
}

enum PaymentMethod {
  QRIS
  OVO
  VIRTUAL_ACCOUNT
  SIMULATION
  CARD
}

enum PaymentStatus {
  CREATED
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum VoucherDiscountType {
  FIXED
  PERCENTAGE
}

enum VoucherStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum NotificationType {
  BOOKING_CONFIRMED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  BOOKING_CANCELLED
  PROMO
  SYSTEM
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum ResellListingStatus {
  DRAFT
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum AuctionStatus {
  DRAFT
  ACTIVE
  ENDED
  CANCELLED
}

enum BidStatus {
  ACTIVE
  OUTBID
  WINNING
  CANCELLED
}

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum WalletTransactionType {
  TOPUP
  PAYMENT
  REFUND
  RESELL_INCOME
  FEE
  ADJUSTMENT
}

enum WalletTransactionDirection {
  CREDIT
  DEBIT
}

enum WalletTransactionStatus {
  PENDING
  POSTED
  FAILED
  REVERSED
}

model User {
  id                 String          @id @default(uuid()) @db.Uuid
  authProvider       String          @map("auth_provider") @db.VarChar(40)
  authProviderUserId String          @map("auth_provider_user_id") @db.VarChar(160)
  email              String?         @unique @db.VarChar(160)
  phone              String?         @unique @db.VarChar(40)
  role               UserRole        @default(USER)
  status             UserStatus      @default(ACTIVE)
  lastLoginAt        DateTime?       @map("last_login_at") @db.Timestamptz(6)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile            UserProfile?
  ownedVenues        Venue[]         @relation("VenueOwner")
  bookings           Booking[]
  payments           Payment[]
  notifications      Notification[]
  reviews            Review[]
  wallet             Wallet?
  resellListings     ResellListing[] @relation("ResellSeller")
  createdAuctions    Auction[]       @relation("AuctionCreator")
  bids               Bid[]
  walletTransactions WalletTransaction[]

  @@unique([authProvider, authProviderUserId])
  @@index([role, status])
  @@map("users")
}

model UserProfile {
  id                       String         @id @default(uuid()) @db.Uuid
  userId                   String         @unique @map("user_id") @db.Uuid
  displayName              String         @map("display_name") @db.VarChar(120)
  avatarUrl                String?        @map("avatar_url") @db.VarChar(500)
  city                     String?        @db.VarChar(120)
  dateOfBirth              DateTime?      @map("date_of_birth") @db.Date
  preferredSportCategoryId String?        @map("preferred_sport_category_id") @db.Uuid
  notificationEnabled      Boolean        @default(true) @map("notification_enabled")
  createdAt                DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredSportCategory   SportCategory? @relation(fields: [preferredSportCategoryId], references: [id], onDelete: SetNull)

  @@index([city])
  @@map("user_profiles")
}

model SportCategory {
  id                   String        @id @default(uuid()) @db.Uuid
  name                 String        @unique @db.VarChar(80)
  slug                 String        @unique @db.VarChar(100)
  description          String?       @db.Text
  iconUrl              String?       @map("icon_url") @db.VarChar(500)
  sortOrder            Int           @default(0) @map("sort_order")
  isActive             Boolean       @default(true) @map("is_active")
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  venues               Venue[]
  courts               Court[]
  preferredByProfiles  UserProfile[]
  bookingItems         BookingItem[]

  @@index([isActive, sortOrder])
  @@map("sport_categories")
}

model Venue {
  id              String          @id @default(uuid()) @db.Uuid
  ownerUserId     String?         @map("owner_user_id") @db.Uuid
  sportCategoryId String          @map("sport_category_id") @db.Uuid
  name            String          @db.VarChar(160)
  slug            String          @unique @db.VarChar(180)
  description     String          @db.Text
  addressLine     String          @map("address_line") @db.VarChar(240)
  city            String          @db.VarChar(120)
  district        String?         @db.VarChar(120)
  province        String?         @db.VarChar(120)
  postalCode      String?         @map("postal_code") @db.VarChar(30)
  latitude        Decimal?        @db.Decimal(9, 6)
  longitude       Decimal?        @db.Decimal(9, 6)
  basePrice       Int             @map("base_price")
  currency        String          @default("IDR") @db.VarChar(3)
  ratingAverage   Decimal         @default(0) @map("rating_average") @db.Decimal(3, 2)
  ratingCount     Int             @default(0) @map("rating_count")
  status          VenueStatus     @default(DRAFT)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz(6)

  owner           User?           @relation("VenueOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  sportCategory   SportCategory   @relation(fields: [sportCategoryId], references: [id], onDelete: Restrict)
  courts          Court[]
  images          VenueImage[]
  facilities      VenueFacility[]
  bookingItems    BookingItem[]
  reviews         Review[]
  auctions        Auction[]

  @@index([sportCategoryId])
  @@index([city, district])
  @@index([status])
  @@index([basePrice])
  @@index([ratingAverage])
  @@index([ownerUserId])
  @@map("venues")
}

model Court {
  id              String         @id @default(uuid()) @db.Uuid
  venueId         String         @map("venue_id") @db.Uuid
  sportCategoryId String?        @map("sport_category_id") @db.Uuid
  name            String         @db.VarChar(120)
  description     String?        @db.Text
  pricePerHour    Int            @map("price_per_hour")
  currency        String         @default("IDR") @db.VarChar(3)
  capacity        Int?
  isIndoor        Boolean        @default(true) @map("is_indoor")
  status          CourtStatus    @default(ACTIVE)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz(6)

  venue           Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sportCategory   SportCategory? @relation(fields: [sportCategoryId], references: [id], onDelete: SetNull)
  images          VenueImage[]
  slots           Slot[]
  bookingItems    BookingItem[]

  @@unique([venueId, name])
  @@index([venueId, status])
  @@index([sportCategoryId])
  @@map("courts")
}

model VenueImage {
  id        String   @id @default(uuid()) @db.Uuid
  venueId   String   @map("venue_id") @db.Uuid
  courtId   String?  @map("court_id") @db.Uuid
  url       String   @db.VarChar(500)
  altText   String?  @map("alt_text") @db.VarChar(180)
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  court     Court?   @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([venueId, isPrimary])
  @@index([courtId])
  @@map("venue_images")
}

model Facility {
  id        String          @id @default(uuid()) @db.Uuid
  name      String          @unique @db.VarChar(80)
  slug      String          @unique @db.VarChar(100)
  iconKey   String?         @map("icon_key") @db.VarChar(80)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  venues    VenueFacility[]

  @@map("facilities")
}

model VenueFacility {
  venueId    String   @map("venue_id") @db.Uuid
  facilityId String   @map("facility_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  venue      Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([venueId, facilityId])
  @@index([facilityId])
  @@map("venue_facilities")
}

model Slot {
  id            String         @id @default(uuid()) @db.Uuid
  courtId       String         @map("court_id") @db.Uuid
  startAt       DateTime       @map("start_at") @db.Timestamptz(6)
  endAt         DateTime       @map("end_at") @db.Timestamptz(6)
  price         Int
  currency      String         @default("IDR") @db.VarChar(3)
  status        SlotStatus     @default(AVAILABLE)
  holdExpiresAt DateTime?      @map("hold_expires_at") @db.Timestamptz(6)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  court         Court          @relation(fields: [courtId], references: [id], onDelete: Cascade)
  bookingItem   BookingItem?

  @@unique([courtId, startAt, endAt])
  @@index([courtId, startAt])
  @@index([status])
  @@index([holdExpiresAt])
  @@map("slots")
}

model Booking {
  id               String          @id @default(uuid()) @db.Uuid
  bookingCode      String?         @unique @map("booking_code") @db.VarChar(40)
  userId           String          @map("user_id") @db.Uuid
  status           BookingStatus   @default(DRAFT)
  subtotalAmount   Int             @map("subtotal_amount")
  serviceFeeAmount Int             @default(0) @map("service_fee_amount")
  discountAmount   Int             @default(0) @map("discount_amount")
  totalAmount      Int             @map("total_amount")
  currency         String          @default("IDR") @db.VarChar(3)
  voucherId        String?         @map("voucher_id") @db.Uuid
  expiresAt        DateTime?       @map("expires_at") @db.Timestamptz(6)
  confirmedAt      DateTime?       @map("confirmed_at") @db.Timestamptz(6)
  cancelledAt      DateTime?       @map("cancelled_at") @db.Timestamptz(6)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  user             User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  voucher          Voucher?        @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  items            BookingItem[]
  payments         Payment[]
  review           Review?
  resellListing    ResellListing?

  @@index([userId, status])
  @@index([createdAt])
  @@index([voucherId])
  @@map("bookings")
}

model BookingItem {
  id              String            @id @default(uuid()) @db.Uuid
  bookingId       String            @map("booking_id") @db.Uuid
  venueId         String            @map("venue_id") @db.Uuid
  courtId         String            @map("court_id") @db.Uuid
  slotId          String            @unique @map("slot_id") @db.Uuid
  sportCategoryId String            @map("sport_category_id") @db.Uuid
  startAt         DateTime          @map("start_at") @db.Timestamptz(6)
  endAt           DateTime          @map("end_at") @db.Timestamptz(6)
  unitPrice       Int               @map("unit_price")
  status          BookingItemStatus @default(PENDING)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  booking         Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  venue           Venue             @relation(fields: [venueId], references: [id], onDelete: Restrict)
  court           Court             @relation(fields: [courtId], references: [id], onDelete: Restrict)
  slot            Slot              @relation(fields: [slotId], references: [id], onDelete: Restrict)
  sportCategory   SportCategory     @relation(fields: [sportCategoryId], references: [id], onDelete: Restrict)
  resellListings  ResellListing[]
  auctions        Auction[]

  @@index([bookingId])
  @@index([venueId])
  @@index([courtId])
  @@index([sportCategoryId])
  @@index([status])
  @@map("booking_items")
}

model Payment {
  id                String          @id @default(uuid()) @db.Uuid
  bookingId         String          @map("booking_id") @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  provider          PaymentProvider @default(SIMULATION)
  method            PaymentMethod
  amount            Int
  currency          String          @default("IDR") @db.VarChar(3)
  status            PaymentStatus   @default(CREATED)
  providerReference String?         @map("provider_reference") @db.VarChar(160)
  failureReason     String?         @map("failure_reason") @db.Text
  paidAt            DateTime?       @map("paid_at") @db.Timestamptz(6)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  booking           Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@index([providerReference])
  @@map("payments")
}

model Voucher {
  id                String              @id @default(uuid()) @db.Uuid
  code              String              @unique @db.VarChar(40)
  name              String              @db.VarChar(120)
  description       String?             @db.Text
  discountType      VoucherDiscountType @map("discount_type")
  discountValue     Int                 @map("discount_value")
  maxDiscountAmount Int?                @map("max_discount_amount")
  minPurchaseAmount Int?                @map("min_purchase_amount")
  usageLimit        Int?                @map("usage_limit")
  usedCount         Int                 @default(0) @map("used_count")
  startsAt          DateTime?           @map("starts_at") @db.Timestamptz(6)
  endsAt            DateTime?           @map("ends_at") @db.Timestamptz(6)
  status            VoucherStatus       @default(INACTIVE)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  bookings          Booking[]

  @@index([status, startsAt, endsAt])
  @@map("vouchers")
}

model Notification {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @map("user_id") @db.Uuid
  type              NotificationType
  title             String           @db.VarChar(160)
  message           String           @db.Text
  relatedEntityType String?          @map("related_entity_type") @db.VarChar(80)
  relatedEntityId   String?          @map("related_entity_id") @db.Uuid
  isRead            Boolean          @default(false) @map("is_read")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt            DateTime?        @map("read_at") @db.Timestamptz(6)

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([relatedEntityType, relatedEntityId])
  @@map("notifications")
}

model Review {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  venueId   String       @map("venue_id") @db.Uuid
  bookingId String?      @unique @map("booking_id") @db.Uuid
  rating    Int
  comment   String?      @db.Text
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  booking   Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([venueId, status])
  @@index([userId])
  @@map("reviews")
}

model ResellListing {
  id            String              @id @default(uuid()) @db.Uuid
  sellerUserId  String              @map("seller_user_id") @db.Uuid
  bookingId     String              @unique @map("booking_id") @db.Uuid
  bookingItemId String              @map("booking_item_id") @db.Uuid
  listingPrice  Int                 @map("listing_price")
  currency      String              @default("IDR") @db.VarChar(3)
  status        ResellListingStatus @default(DRAFT)
  expiresAt     DateTime            @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  seller        User                @relation("ResellSeller", fields: [sellerUserId], references: [id], onDelete: Restrict)
  booking       Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingItem   BookingItem         @relation(fields: [bookingItemId], references: [id], onDelete: Restrict)
  auctions      Auction[]

  @@index([sellerUserId])
  @@index([bookingItemId])
  @@index([status, expiresAt])
  @@map("resell_listings")
}

model Auction {
  id              String         @id @default(uuid()) @db.Uuid
  resellListingId String?        @map("resell_listing_id") @db.Uuid
  venueId         String?        @map("venue_id") @db.Uuid
  bookingItemId   String?        @map("booking_item_id") @db.Uuid
  createdByUserId String?        @map("created_by_user_id") @db.Uuid
  title           String         @db.VarChar(160)
  startingPrice   Int            @map("starting_price")
  currentPrice    Int            @map("current_price")
  currency        String         @default("IDR") @db.VarChar(3)
  status          AuctionStatus  @default(DRAFT)
  startsAt        DateTime       @map("starts_at") @db.Timestamptz(6)
  endsAt          DateTime       @map("ends_at") @db.Timestamptz(6)
  winnerBidId     String?        @unique @map("winner_bid_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  resellListing   ResellListing? @relation(fields: [resellListingId], references: [id], onDelete: SetNull)
  venue           Venue?         @relation(fields: [venueId], references: [id], onDelete: SetNull)
  bookingItem     BookingItem?   @relation(fields: [bookingItemId], references: [id], onDelete: SetNull)
  createdBy       User?          @relation("AuctionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  winnerBid       Bid?           @relation("AuctionWinner", fields: [winnerBidId], references: [id], onDelete: SetNull)
  bids            Bid[]          @relation("AuctionBids")

  @@index([status, endsAt])
  @@index([resellListingId])
  @@index([venueId])
  @@index([bookingItemId])
  @@index([createdByUserId])
  @@map("auctions")
}

model Bid {
  id           String    @id @default(uuid()) @db.Uuid
  auctionId    String    @map("auction_id") @db.Uuid
  bidderUserId String    @map("bidder_user_id") @db.Uuid
  amount       Int
  currency     String    @default("IDR") @db.VarChar(3)
  status       BidStatus @default(ACTIVE)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  auction      Auction   @relation("AuctionBids", fields: [auctionId], references: [id], onDelete: Cascade)
  bidder       User      @relation(fields: [bidderUserId], references: [id], onDelete: Restrict)
  wonAuction   Auction?  @relation("AuctionWinner")

  @@index([auctionId, amount])
  @@index([bidderUserId])
  @@index([status])
  @@map("bids")
}

model Wallet {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @unique @map("user_id") @db.Uuid
  balance      Int                 @default(0)
  currency     String              @default("IDR") @db.VarChar(3)
  status       WalletStatus        @default(ACTIVE)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id            String                     @id @default(uuid()) @db.Uuid
  walletId      String                     @map("wallet_id") @db.Uuid
  userId        String                     @map("user_id") @db.Uuid
  type          WalletTransactionType
  direction     WalletTransactionDirection
  amount        Int
  currency      String                     @default("IDR") @db.VarChar(3)
  status        WalletTransactionStatus    @default(PENDING)
  referenceType String?                    @map("reference_type") @db.VarChar(80)
  referenceId   String?                    @map("reference_id") @db.Uuid
  createdAt     DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  postedAt      DateTime?                  @map("posted_at") @db.Timestamptz(6)

  wallet        Wallet                     @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([userId])
  @@index([referenceType, referenceId])
  @@index([status])
  @@map("wallet_transactions")
}
