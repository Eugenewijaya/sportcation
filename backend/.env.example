NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://sportcation_user:change_me@localhost:5432/sportcation

# Auth API
# Use a long random value in shared environments. Development falls back to an ephemeral secret if omitted.
AUTH_TOKEN_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
AUTH_ACCESS_TOKEN_TTL_SECONDS=1800
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_EXPOSE_SIMULATED_OTP=true
